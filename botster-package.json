{
  "name": "botster-tui",
  "version": "0.1.0",
  "kind": "plugin",
  "botster": ">=0.1.0",
  "source": null,
  "capabilities": [],
  "entrypoints": [
    {
      "runtime": "lua",
      "path": "plugin.lua",
      "bootstrap": false
    }
  ],
  "runnable_entrypoints": [
    {
      "id": "tui",
      "kind": "terminal_app",
      "launch_mode": "foreground_stdio",
      "command": "target/debug/botster-tui",
      "args": [],
      "working_directory": {
        "policy": "package_root"
      },
      "injections": [
        {
          "kind": "hub_connection",
          "target": {
            "type": "environment",
            "name": "BOTSTER_HUB_CONNECTION"
          },
          "required": true,
          "description": "Typed Hub connection descriptor supplied by the host."
        },
        {
          "kind": "data_dir",
          "target": {
            "type": "environment",
            "name": "BOTSTER_HUB_DATA_DIR"
          },
          "required": true,
          "description": "Hub-owned package storage context shown in System details."
        }
      ]
    }
  ]
}
