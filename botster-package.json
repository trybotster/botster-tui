{
  "name": "botster-tui",
  "version": "0.1.0",
  "kind": "plugin",
  "botster": ">=0.1.0",
  "source": null,
  "capabilities": [],
  "entrypoints": [
    {
      "runtime": "lua",
      "path": "plugin.lua",
      "bootstrap": false
    }
  ],
  "runnable_entrypoints": [
    {
      "id": "tui",
      "kind": "terminal_app",
      "launch_mode": "foreground_stdio",
      "command": "target/debug/botster-tui",
      "args": [],
      "working_directory": {
        "policy": "package_root"
      },
      "injections": [
        {
          "kind": "hub_connection",
          "target": {
            "type": "environment",
            "name": "BOTSTER_HUB_SOCKET"
          },
          "required": true,
          "description": "Hub socket supplied by the host."
        },
        {
          "kind": "data_dir",
          "target": {
            "type": "environment",
            "name": "BOTSTER_HUB_DATA_DIR"
          },
          "required": true,
          "description": "Hub data directory supplied by the host."
        },
        {
          "kind": "hub_socket",
          "target": {
            "type": "environment",
            "name": "BOTSTER_HUB_SOCKET"
          },
          "required": true,
          "description": "Hub socket supplied by the host."
        }
      ],
      "environment": [
        {
          "name": "BOTSTER_HUB_SOCKET",
          "required": false,
          "description": "Fallback hub socket environment variable consumed by botster-tui when --hub-socket is not supplied."
        },
        {
          "name": "BOTSTER_HUB_CONNECTION",
          "required": false,
          "description": "Legacy host-selected hub connection descriptor."
        },
        {
          "name": "BOTSTER_HUB_DATA_DIR",
          "required": true,
          "description": "Host-selected hub data directory."
        }
      ]
    }
  ]
}
